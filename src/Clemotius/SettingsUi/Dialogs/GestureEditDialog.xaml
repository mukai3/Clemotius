<ui:FluentWindow
    x:Class="Clemotius.SettingsUi.Dialogs.GestureEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:dialogs="clr-namespace:Clemotius.SettingsUi.Dialogs"
    Title="ジェスチャーの編集"
    Width="440"
    MinWidth="0"
    MinHeight="0"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="DialogTitleBar"
            Grid.Row="0"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,8,20,20">

            <!--  親(設定画面)に合わせ「ラベル左寄せ + 入力欄は右側の固定250px列」で統一  -->
            <Grid x:Name="StrokeRow" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="ストローク" />
                <Grid Grid.Column="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ui:TextBox
                        x:Name="StrokesBox"
                        CharacterCasing="Upper"
                        PlaceholderText="U/D/L/R, WU/WD" />
                    <ui:Button
                        Grid.Column="2"
                        Click="OnCaptureStroke"
                        Content="マウスで入力..." />
                </Grid>
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="アクション種別" />
                <ComboBox
                    x:Name="TypeCombo"
                    Grid.Column="1"
                    SelectionChanged="OnTypeChanged" />
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="ParamLabel"
                    VerticalAlignment="Center"
                    Text="キー" />
                <dialogs:KeyCaptureBox
                    x:Name="KeysBox"
                    Grid.Column="1"
                    AutomationProperties.HelpText="欄をクリックして割り当てたいキーを押してください。Tab で次の項目へ移動できます。"
                    AutomationProperties.Name="ショートカットキー"
                    Style="{StaticResource {x:Type ui:TextBox}}" />
                <ComboBox x:Name="CommandCombo" Grid.Column="1" />
                <ComboBox
                    x:Name="PresetCombo"
                    Grid.Column="1"
                    DisplayMemberPath="Display" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button
                    Grid.Column="1"
                    MinWidth="90"
                    Appearance="Primary"
                    Click="OnOk"
                    Content="OK"
                    IsDefault="True" />
                <ui:Button
                    Grid.Column="3"
                    MinWidth="90"
                    Click="OnCancel"
                    Content="キャンセル"
                    IsCancel="True" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>

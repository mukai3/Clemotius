<ui:FluentWindow
    x:Class="Clemotius.SettingsUi.Dialogs.GestureEditDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:dialogs="clr-namespace:Clemotius.SettingsUi.Dialogs"
    Title="ジェスチャーの編集"
    Width="440"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    SizeToContent="Height"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            x:Name="DialogTitleBar"
            Grid.Row="0"
            ShowMaximize="False"
            ShowMinimize="False" />

        <StackPanel Grid.Row="1" Margin="20,8,20,20">

            <Grid x:Name="StrokeRow" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="ストローク (U/D/L/R)" />
                <TextBox
                    x:Name="StrokesBox"
                    Grid.Column="1"
                    CharacterCasing="Upper" />
                <ui:Button
                    Grid.Column="3"
                    Click="OnCaptureStroke"
                    Content="マウスで入力..." />
            </Grid>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="アクション種別" />
                <ComboBox
                    x:Name="TypeCombo"
                    Grid.Column="1"
                    SelectionChanged="OnTypeChanged" />
            </Grid>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    x:Name="ParamLabel"
                    VerticalAlignment="Center"
                    Text="キー" />
                <dialogs:KeyCaptureBox
                    x:Name="KeysBox"
                    Grid.Column="1"
                    AutomationProperties.HelpText="欄をクリックして割り当てたいキーを押してください。Tab で次の項目へ移動できます。"
                    AutomationProperties.Name="ショートカットキー" />
                <ComboBox x:Name="CommandCombo" Grid.Column="1" />
                <ComboBox
                    x:Name="PresetCombo"
                    Grid.Column="1"
                    DisplayMemberPath="Display" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:Button
                    x:Name="ClearButton"
                    Grid.Column="0"
                    Click="OnClearAssignment"
                    Content="割当なし"
                    Visibility="Collapsed" />
                <ui:Button
                    Grid.Column="2"
                    MinWidth="90"
                    Appearance="Primary"
                    Click="OnOk"
                    Content="OK"
                    IsDefault="True" />
                <ui:Button
                    Grid.Column="4"
                    MinWidth="90"
                    Click="OnCancel"
                    Content="キャンセル"
                    IsCancel="True" />
            </Grid>
        </StackPanel>
    </Grid>
</ui:FluentWindow>

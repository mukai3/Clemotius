<ui:FluentWindow
    x:Class="Clemotius.SettingsUi.Dialogs.StrokeCaptureDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ストロークの入力"
    Width="400"
    Height="420"
    ExtendsContentIntoTitleBar="True"
    ResizeMode="NoResize"
    WindowBackdropType="Mica"
    WindowCornerPreference="Round"
    WindowStartupLocation="CenterOwner">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ui:TitleBar
            Grid.Row="0"
            Title="ストロークの入力"
            ShowMaximize="False"
            ShowMinimize="False" />

        <TextBlock
            x:Name="Preview"
            Grid.Row="1"
            Margin="0,8"
            HorizontalAlignment="Center"
            FontSize="22"
            FontWeight="SemiBold" />

        <Border
            x:Name="CanvasBorder"
            Grid.Row="2"
            Margin="16,0"
            AutomationProperties.HelpText="左右どちらかのボタンでドラッグして軌跡を描くと、ストローク(U/D/L/R)が確定します。ホイールを回すと右ボタン+ホイール(WU/WD)になります。キーボードで入力する場合は前の画面のストローク欄に直接 U/D/L/R または WU/WD を入力できます。"
            AutomationProperties.Name="ストローク描画エリア"
            Background="{DynamicResource ControlFillColorDefaultBrush}"
            BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Focusable="True"
            MouseDown="OnCanvasMouseDown"
            MouseMove="OnCanvasMouseMove"
            MouseUp="OnCanvasMouseUp"
            MouseWheel="OnCanvasWheel">
            <Canvas x:Name="TrailCanvas" Background="Transparent" ClipToBounds="True">
                <Polyline
                    x:Name="Trail"
                    Stroke="{DynamicResource TextFillColorPrimaryBrush}"
                    StrokeEndLineCap="Round"
                    StrokeLineJoin="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="3" />
            </Canvas>
        </Border>

        <TextBlock
            Grid.Row="3"
            Margin="0,8"
            HorizontalAlignment="Center"
            Opacity="0.7"
            Text="左/右ボタンでドラッグ → 離すと確定 ／ ホイールを回す → WU/WD" />

        <Grid Grid.Row="4" Margin="16,0,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:Button Grid.Column="0" Click="OnClear" Content="クリア" />
            <ui:Button
                Grid.Column="2"
                MinWidth="90"
                Appearance="Primary"
                Click="OnOk"
                Content="OK"
                IsDefault="True" />
            <ui:Button
                Grid.Column="4"
                MinWidth="90"
                Click="OnCancel"
                Content="キャンセル"
                IsCancel="True" />
        </Grid>
    </Grid>
</ui:FluentWindow>

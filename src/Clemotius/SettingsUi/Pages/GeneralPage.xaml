<Page
    x:Class="Clemotius.SettingsUi.Pages.GeneralPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Clemotius.SettingsUi"
    Title="一般">
    <Page.Resources>
        <local:HexBrushConverter x:Key="HexBrush" />
    </Page.Resources>
    <ScrollViewer Padding="24,16" VerticalScrollBarVisibility="Auto">
        <StackPanel MaxWidth="640" HorizontalAlignment="Stretch">

            <TextBlock
                Margin="0,0,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Text="トレイ" />
            <ui:ToggleSwitch
                Margin="0,0,0,8"
                Content="タスクトレイにアイコンを表示する"
                IsChecked="{Binding General.ShowTrayIcon}" />
            <ui:ToggleSwitch
                Margin="0,0,0,8"
                Content="バルーン通知を表示する"
                IsChecked="{Binding General.ShowBalloonTip}" />

            <TextBlock
                Margin="0,16,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Text="ジェスチャーの詳細" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="1 ストロークの距離 (px)" />
                <ui:NumberBox
                    Grid.Column="1"
                    ClearButtonEnabled="False"
                    MaxDecimalPlaces="0"
                    Maximum="100"
                    Minimum="1"
                    SmallChange="1"
                    Value="{Binding General.Range}" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="入力開始のタイムアウト (ms)" />
                <ui:NumberBox
                    Grid.Column="1"
                    ClearButtonEnabled="False"
                    MaxDecimalPlaces="0"
                    Maximum="10000"
                    Minimum="0"
                    SmallChange="100"
                    Value="{Binding General.TimeoutMs}" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="長押しの待ち時間 (ms)" />
                <ui:NumberBox
                    Grid.Column="1"
                    ClearButtonEnabled="False"
                    MaxDecimalPlaces="0"
                    Maximum="5000"
                    Minimum="0"
                    SmallChange="50"
                    Value="{Binding General.PushHoldTimeMs}" />
            </Grid>

            <TextBlock
                Margin="0,16,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Text="軌跡 / コマンド表示" />
            <ui:ToggleSwitch
                Margin="0,0,0,8"
                Content="ジェスチャーの軌跡/コマンドを表示する"
                IsChecked="{Binding General.DrawStroke}" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="表示方法" />
                <ComboBox Grid.Column="1" SelectedIndex="{Binding General.DrawingType}">
                    <ComboBoxItem Content="軌跡(線)" />
                    <ComboBoxItem Content="コマンド表示" />
                </ComboBox>
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="幅 (px)" />
                <ui:NumberBox
                    Grid.Column="1"
                    ClearButtonEnabled="False"
                    MaxDecimalPlaces="0"
                    Maximum="20"
                    Minimum="1"
                    SmallChange="1"
                    Value="{Binding General.StrokeWidth}" />
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="10" />
                    <ColumnDefinition Width="120" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="色 (有効 / 無効)" />
                <Button
                    Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Click="OnPickValidColor">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="14"
                            Height="14"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{Binding General.ValidStrokeColor, Converter={StaticResource HexBrush}}"
                            CornerRadius="3" />
                        <TextBlock Text="有効色" />
                    </StackPanel>
                </Button>
                <Button
                    Grid.Column="3"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Center"
                    Click="OnPickInvalidColor">
                    <StackPanel Orientation="Horizontal">
                        <Border
                            Width="14"
                            Height="14"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Background="{Binding General.InvalidStrokeColor, Converter={StaticResource HexBrush}}"
                            CornerRadius="3" />
                        <TextBlock Text="無効色" />
                    </StackPanel>
                </Button>
            </Grid>

            <TextBlock
                Margin="0,16,0,4"
                FontSize="16"
                FontWeight="SemiBold"
                Text="ジェスチャーを無効にするアプリ" />
            <TextBlock
                Margin="0,0,0,12"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                Text="登録したアプリでは Clemotius の右ボタンジェスチャーを使わず、アプリ独自のマウスジェスチャーをそのまま使えます。（例: JaneStyle）" />
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:TextBox
                    PlaceholderText="プロセス名（例: JaneStyle または JaneStyle.exe）"
                    Text="{Binding General.NewProcessName, UpdateSourceTrigger=PropertyChanged}">
                    <ui:TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding General.AddExcludedProcessCommand}" />
                    </ui:TextBox.InputBindings>
                </ui:TextBox>
                <Button
                    Grid.Column="2"
                    Command="{Binding General.AddExcludedProcessCommand}"
                    Content="追加" />
            </Grid>
            <ItemsControl ItemsSource="{Binding General.ExcludedProcesses}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="{Binding}" />
                            <Button
                                Grid.Column="1"
                                Padding="8,2"
                                Command="{Binding DataContext.General.RemoveExcludedProcessCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                CommandParameter="{Binding}"
                                Content="削除" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</Page>

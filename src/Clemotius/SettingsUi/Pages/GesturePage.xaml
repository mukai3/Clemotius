<Page
    x:Class="Clemotius.SettingsUi.Pages.GesturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:local="clr-namespace:Clemotius.SettingsUi"
    Title="ジェスチャー">
    <Page.Resources>
        <local:EmptyCountToVisibilityConverter x:Key="EmptyToVisible" />
    </Page.Resources>
    <Grid Margin="24,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  プロファイルバー  -->
        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                Text="プロファイル:" />
            <ComboBox
                Grid.Column="1"
                Margin="0,0,8,0"
                DisplayMemberPath="DisplayName"
                ItemsSource="{Binding Gesture.Profiles}"
                SelectedItem="{Binding Gesture.SelectedProfile}" />
            <ui:Button
                Grid.Column="2"
                Click="OnAddProfile"
                Content="追加" />
            <ui:Button
                x:Name="EditProfileButton"
                Grid.Column="4"
                Click="OnEditProfile"
                Content="編集" />
            <ui:Button
                Grid.Column="6"
                Click="OnRemoveProfile"
                Content="削除"
                IsEnabled="{Binding Gesture.SelectedIsRemovable}" />
        </Grid>

        <!--  ジェスチャー一覧（GridView は WPF-UI のテーマに追従しないため、通常 ListView+テンプレートで構成）  -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <!--  ヘッダー行（列幅は行テンプレートと揃える: 120 / *）  -->
            <Grid Grid.Row="0" Margin="12,0,12,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="ストローク" />
                <TextBlock
                    Grid.Column="1"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                    Text="アクション" />
            </Grid>
            <ListView
                x:Name="GestureList"
                Grid.Row="1"
                Background="Transparent"
                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                ItemsSource="{Binding Gesture.Gestures}"
                MouseDoubleClick="OnEditGesture"
                SelectionChanged="OnGestureSelectionChanged">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <!--  ListView 既定スタイルは黒文字を強制するため、テーマ追従の文字色を明示する  -->
                        <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding Arrows}" />
                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding Description}"
                                TextTrimming="CharacterEllipsis"
                                ToolTip="{Binding Description}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!--  一覧が空のときの案内（リスト本体の中央。列ヘッダーに重ならないよう Center 配置）  -->
        <TextBlock
            Grid.Row="1"
            Margin="24,28,24,12"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            IsHitTestVisible="False"
            TextAlignment="Center"
            Text="ジェスチャーはまだ登録されていません。下の「追加」から登録できます。"
            TextWrapping="Wrap"
            Visibility="{Binding Gesture.Gestures.Count, Converter={StaticResource EmptyToVisible}}" />

        <StackPanel
            Grid.Row="2"
            Margin="0,8,0,0"
            Orientation="Horizontal">
            <ui:Button
                Margin="0,0,8,0"
                Click="OnAddGesture"
                Content="追加" />
            <ui:Button
                x:Name="EditGestureButton"
                Margin="0,0,8,0"
                Click="OnEditGesture"
                Content="編集"
                IsEnabled="False" />
            <ui:Button
                x:Name="RemoveGestureButton"
                Click="OnRemoveGesture"
                Content="削除"
                IsEnabled="False" />
        </StackPanel>

        <!--
            プロファイル編集オーバーレイ。Popup は別 HWND になり、WinForms ループ上で
            .Show() した WPF ウィンドウ配下ではキーボードフォーカスが渡らない（テキスト入力不可）。
            同一ウィンドウ内に重ねて描画することでフォーカス問題を回避する。全行に重ねるため
            最後の子として配置し、ルート Grid のマージン分は負マージンで打ち消す。
        -->
        <Grid
            x:Name="ProfileEditorOverlay"
            Grid.Row="0"
            Grid.RowSpan="3"
            Margin="-24,-16"
            Background="#80000000"
            Visibility="Collapsed">
            <Border
                Width="320"
                Padding="16"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource ApplicationBackgroundBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect
                        BlurRadius="16"
                        Opacity="0.4"
                        ShadowDepth="4" />
                </Border.Effect>
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,12"
                        FontWeight="SemiBold"
                        Text="プロファイルの編集" />
                    <TextBlock Margin="0,0,0,4" Opacity="0.8" Text="プロファイル名" />
                    <TextBox
                        x:Name="FlyoutName"
                        Margin="0,0,0,8"
                        TextChanged="OnFlyoutInputChanged" />
                    <TextBlock Margin="0,0,0,4" Opacity="0.8" Text="対象プロセス (カンマ区切りで複数可)" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            x:Name="FlyoutPattern"
                            Grid.Column="0"
                            TextChanged="OnFlyoutInputChanged" />
                        <ui:Button
                            x:Name="FlyoutPickButton"
                            Grid.Column="2"
                            Click="OnPickProfileProcesses"
                            Content="選択..." />
                    </Grid>
                    <ui:ToggleSwitch
                        x:Name="FlyoutEnabled"
                        Margin="0,0,0,8"
                        Content="ジェスチャーを有効にする" />
                    <TextBlock
                        x:Name="FlyoutError"
                        Margin="0,0,0,8"
                        Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                        TextWrapping="Wrap"
                        Visibility="Collapsed" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="8" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ui:Button
                            x:Name="FlyoutSave"
                            Grid.Column="1"
                            Appearance="Primary"
                            Click="OnFlyoutSave"
                            Content="保存" />
                        <ui:Button
                            Grid.Column="3"
                            Click="OnFlyoutCancel"
                            Content="キャンセル" />
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>

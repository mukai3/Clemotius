<Page
    x:Class="Clemotius.SettingsUi.Pages.WindowPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    Title="ウィンドウ">
    <ScrollViewer
        Padding="24,16"
        Background="Transparent"
        VerticalScrollBarVisibility="Visible">
        <StackPanel MaxWidth="640" HorizontalAlignment="Stretch">
            <TextBlock
                Margin="0,0,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Text="タイトルバー アクション" />
            <ItemsControl ItemsSource="{Binding TitlebarSlots}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="250" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Text="{Binding Label}" />
                            <ComboBox
                                Grid.Column="1"
                                DisplayMemberPath="Display"
                                ItemsSource="{Binding Choices}"
                                SelectedValue="{Binding Value}"
                                SelectedValuePath="Value" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
                Margin="0,16,0,12"
                FontSize="16"
                FontWeight="SemiBold"
                Text="半透明化" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="250" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Text="不透明度 (%)" />
                <ui:NumberBox
                    Grid.Column="1"
                    ClearButtonEnabled="False"
                    MaxDecimalPlaces="0"
                    Maximum="90"
                    Minimum="10"
                    SmallChange="5"
                    Value="{Binding WindowOpacity}" />
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
